                                <th class="p-4 text-sm font-bold text-gray-700 text-right">Pemasukan Lain</th>
                                <th class="p-4 text-sm font-bold text-gray-700 text-right bg-green-50">Total Pemasukan</th>
                                <th class="p-4 text-sm font-bold text-gray-700 text-right">Pengeluaran</th>
                                <th class="p-4 text-sm font-bold text-gray-700 text-right">Kas/Bulan</th>
                                <th class="p-4 text-sm font-bold text-gray-700 text-right bg-indigo-100">Total Kas</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            <% riwayatKeuangan.forEach(function(item) { 
                                var isBulanBerjalan = item.bulan === bulanBerjalan;
                            %>
                                <tr class="hover:bg-gray-50 transition <%= isBulanBerjalan ? 'bg-yellow-50 border-l-4 border-yellow-500' : '' %>">
                                    <td class="p-4">
                                        <div class="flex items-center gap-2">
                                            <span class="font-semibold text-gray-800"><%= item.bulan %> 2026</span>
                                            <% if (isBulanBerjalan) { %>
                                                <span class="text-xs bg-yellow-200 text-yellow-800 px-2 py-0.5 rounded-full font-semibold">Berjalan</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="p-4 text-right">
                                        <span class="text-sm text-emerald-600">Rp <%= item.pemasukanIuran.toLocaleString('id-ID') %></span>
                                    </td>
                                    <td class="p-4 text-right">
                                        <span class="text-sm text-teal-600">Rp <%= item.pemasukanLain.toLocaleString('id-ID') %></span>
                                    </td>
                                    <td class="p-4 text-right bg-green-50">
                                        <span class="font-semibold text-green-600">+ Rp <%= item.pemasukan.toLocaleString('id-ID') %></span>
                                    </td>
                                    <td class="p-4 text-right">
                                        <span class="font-semibold text-red-600">- Rp <%= item.pengeluaran.toLocaleString('id-ID') %></span>
                                    </td>
                                    <td class="p-4 text-right">
                                        <span class="font-bold <%= item.sisaKas >= 0 ? 'text-blue-600' : 'text-red-600' %>">
                                            Rp <%= item.sisaKas.toLocaleString('id-ID') %>
                                        </span>
                                    </td>
                                    <td class="p-4 text-right bg-indigo-50">
                                        <span class="font-bold text-lg <%= item.kumulatif >= 0 ? 'text-indigo-700' : 'text-red-700' %>">
                                            Rp <%= item.kumulatif.toLocaleString('id-ID') %>
                                        </span>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>

                <!-- Statistik Ringkas -->
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                    <% 
                        var totalPemasukanTahunan = riwayatKeuangan.reduce(function(sum, item) { return sum + item.pemasukan; }, 0);
                        var totalPengeluaranTahunan = riwayatKeuangan.reduce(function(sum, item) { return sum + item.pengeluaran; }, 0);
                        var kasTerakhir = riwayatKeuangan[riwayatKeuangan.length - 1].kumulatif;
                        var bulanSurplus = riwayatKeuangan.filter(function(item) { return item.sisaKas > 0; }).length;
                    %>
                    
                    <div class="bg-green-50 border-2 border-green-200 rounded-xl p-4 text-center">
                        <p class="text-xs text-green-600 font-medium mb-1">Total Pemasukan (Jan-Des)</p>
                        <p class="text-xl font-bold text-green-700">Rp <%= totalPemasukanTahunan.toLocaleString('id-ID') %></p>
                    </div>
                    
                    <div class="bg-red-50 border-2 border-red-200 rounded-xl p-4 text-center">
                        <p class="text-xs text-red-600 font-medium mb-1">Total Pengeluaran (Jan-Des)</p>
                        <p class="text-xl font-bold text-red-700">Rp <%= totalPengeluaranTahunan.toLocaleString('id-ID') %></p>
                    </div>
                    
                    <div class="bg-indigo-50 border-2 border-indigo-200 rounded-xl p-4 text-center">
                        <p class="text-xs text-indigo-600 font-medium mb-1">Kas Akhir Tahun</p>
                        <p class="text-xl font-bold text-indigo-700">Rp <%= kasTerakhir.toLocaleString('id-ID') %></p>
                    </div>
                    
                    <div class="bg-purple-50 border-2 border-purple-200 rounded-xl p-4 text-center">
                        <p class="text-xs text-purple-600 font-medium mb-1">Bulan Surplus</p>
                        <p class="text-xl font-bold text-purple-700"><%= bulanSurplus %> / 12 Bulan</p>
                    </div>
                </div>

                <!-- Info & Keterangan -->
                <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-4">
                    <h3 class="font-semibold text-blue-900 mb-2">📌 Keterangan:</h3>
                    <ul class="text-sm text-blue-800 space-y-1">
                        <li>• <strong>Pemasukan Iuran:</strong> Total iuran warga yang sudah lunas</li>
                        <li>• <strong>Pemasukan Lain:</strong> Pemasukan di luar iuran (sewa fasilitas, denda, sumbangan, dll)</li>
                        <li>• <strong>Total Pemasukan:</strong> Pemasukan Iuran + Pemasukan Lain</li>
                        <li>• <strong>Pengeluaran:</strong> Total pengeluaran kas yang tercatat</li>
                        <li>• <strong>Kas/Bulan:</strong> Total Pemasukan - Pengeluaran per bulan</li>
                        <li>• <strong>Total Kas:</strong> Akumulasi kas dari Januari sampai bulan tersebut</li>
                        <li>• Baris dengan highlight kuning = Bulan berjalan saat ini</li>
                    </ul>
                </div>
            </div>

            <!-- Footer dengan Tombol Download (Mobile Responsive) -->
            <div class="border-t border-gray-200 p-4 sm:p-6 bg-gray-50 modal-footer-sticky flex-shrink-0">
                <!-- Tombol Download - Prioritas Utama (Tampil di Atas pada Mobile) -->
                <div class="flex flex-col sm:flex-row gap-3 mb-4">
                    <a href="/download-keuangan" class="w-full sm:w-auto bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 text-white font-bold px-6 py-3 rounded-xl shadow-lg transition flex items-center justify-center gap-2 btn-download-mobile">
                        <span>💾</span>
                        <span>Download Excel</span>
                    </a>
                    <% if (!isAdmin) { %>
                        <button onclick="tutupRiwayatKeuangan()" class="w-full sm:w-auto bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold px-6 py-3 rounded-xl transition btn-download-mobile">
                            Tutup
                        </button>
                    <% } %>
                </div>
                
                <!-- Info Text -->
                <p class="text-xs sm:text-sm text-gray-600 text-center sm:text-left">
                    <% if (isAdmin) { %>
                        💡 <strong>Tip:</strong> Cek data dulu sebelum download Excel untuk memastikan data sudah benar
                    <% } else { %>
                        🔍 <strong>Transparansi:</strong> Anda dapat download laporan keuangan untuk arsip pribadi
                    <% } %>
                </p>
            </div>
        </div>
    </div>

	<script>
        // Fungsi Filter/Search Tabel Utama
        function filterTable() {
            var searchInput = document.getElementById('searchInput').value.toLowerCase();
            var filterStatus = document.getElementById('filterStatus') ? document.getElementById('filterStatus').value : '';
            var filterNominal = document.getElementById('filterNominal') ? document.getElementById('filterNominal').value : '';
            
            var table = document.getElementById('tableBody');
            var tr = table.getElementsByClassName('table-row');
            var visibleCount = 0;
            
            for (var i = 0; i < tr.length; i++) {
                var rumah = tr[i].getAttribute('data-rumah');
                var nama = tr[i].getAttribute('data-nama');
                var status = tr[i].getAttribute('data-status');
                var nominal = tr[i].getAttribute('data-nominal');
                
                var matchSearch = rumah.indexOf(searchInput) > -1 || nama.indexOf(searchInput) > -1;
                var matchStatus = filterStatus === '' || status === filterStatus;
                var matchNominal = filterNominal === '' || nominal === filterNominal;
                
                if (matchSearch && matchStatus && matchNominal) {
                    tr[i].style.display = '';
                    visibleCount++;
                } else {
                    tr[i].style.display = 'none';
                }
            }
            
            // Show result count
            var resultEl = document.getElementById('searchResult');
            var countEl = document.getElementById('resultCount');
            if (searchInput || filterStatus || filterNominal) {
                resultEl.classList.remove('hidden');
                countEl.textContent = visibleCount;
            } else {
                resultEl.classList.add('hidden');
            }
        }

        // Fungsi Filter untuk Modal Warga
        function filterModalTableWarga(bulan) {
            var searchInput = document.getElementById('searchModalWarga' + bulan).value.toLowerCase();
            var tbody = document.getElementById('tableBodyWarga' + bulan);
            var tr = tbody.getElementsByClassName('row-warga-' + bulan);
            var visibleCount = 0;
            
            for (var i = 0; i < tr.length; i++) {
                var rumah = tr[i].getAttribute('data-rumah');
                var nama = tr[i].getAttribute('data-nama');
                
                var matchSearch = rumah.indexOf(searchInput) > -1 || nama.indexOf(searchInput) > -1;
                
                if (matchSearch) {
                    tr[i].style.display = '';
                    visibleCount++;
                } else {
                    tr[i].style.display = 'none';
                }
            }
            
            // Show result count
            var resultEl = document.getElementById('searchResultWarga' + bulan);
            var countEl = document.getElementById('resultCountWarga' + bulan);
            if (searchInput) {
                resultEl.classList.remove('hidden');
                countEl.textContent = visibleCount;
            } else {
                resultEl.classList.add('hidden');
            }
        }

        function bukaModeEdit(id) {
            document.getElementById('row-view-' + id).classList.add('hidden');
            document.getElementById('row-edit-' + id).classList.remove('hidden');
        }

        function tutupModeEdit(id) {
            document.getElementById('row-view-' + id).classList.remove('hidden');
            document.getElementById('row-edit-' + id).classList.add('hidden');
        }

        // Fungsi untuk Modal Riwayat Warga (untuk NON-ADMIN)
        function bukaRiwayatWarga() {
            document.getElementById('modalRiwayatWarga').classList.remove('hidden');
        }

        function tutupRiwayatWarga() {
            document.getElementById('modalRiwayatWarga').classList.add('hidden');
            // Reset tampilan
            sembunyikanSemuaTabelWarga();
            document.getElementById('pesan-pilih-warga').classList.remove('hidden');
        }

        function sembunyikanSemuaTabelWarga() {
            <% semuaBulan.forEach(function(bulan) { %>
                var el = document.getElementById('tabel-warga-<%= bulan %>');
                if (el) el.classList.add('hidden');
            <% }); %>
        }

        function tampilkanBulanWarga(bulan) {
            // Sembunyikan pesan default
            document.getElementById('pesan-pilih-warga').classList.add('hidden');
            
            // Sembunyikan semua tabel
            sembunyikanSemuaTabelWarga();
            
            // Tampilkan tabel bulan yang dipilih
            document.getElementById('tabel-warga-' + bulan).classList.remove('hidden');
        }

        // Tutup modal jika klik di luar (untuk warga)
        var modalRiwayatWarga = document.getElementById('modalRiwayatWarga');
        if (modalRiwayatWarga) {
            modalRiwayatWarga.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupRiwayatWarga();
                }
            });
        }

        // Fungsi untuk Modal Riwayat Keuangan (UNTUK SEMUA USER)
        function bukaRiwayatKeuangan() {
            document.getElementById('modalRiwayatKeuangan').classList.remove('hidden');
        }

        function tutupRiwayatKeuangan() {
            document.getElementById('modalRiwayatKeuangan').classList.add('hidden');
        }

        var modalRiwayatKeuangan = document.getElementById('modalRiwayatKeuangan');
        if (modalRiwayatKeuangan) {
            modalRiwayatKeuangan.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupRiwayatKeuangan();
                }
            });
        }

        // Fungsi untuk Modal List Pengeluaran (UNTUK SEMUA USER)
        function bukaListPengeluaran() {
            document.getElementById('modalListPengeluaran').classList.remove('hidden');
        }

        function tutupListPengeluaran() {
            document.getElementById('modalListPengeluaran').classList.add('hidden');
        }

        var modalListPengeluaran = document.getElementById('modalListPengeluaran');
        if (modalListPengeluaran) {
            modalListPengeluaran.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupListPengeluaran();
                }
            });
        }

        <% if (isAdmin) { %>
        // Fungsi untuk Modal Riwayat (Hanya untuk Admin)
        function bukaRiwayat() {
            document.getElementById('modalRiwayat').classList.remove('hidden');
        }

        function tutupRiwayat() {
            document.getElementById('modalRiwayat').classList.add('hidden');
            // Reset tampilan
            sembunyikanSemuaTabel();
            document.getElementById('pesan-pilih').classList.remove('hidden');
        }

        function sembunyikanSemuaTabel() {
            <% semuaBulan.forEach(function(bulan) { %>
                var el = document.getElementById('tabel-<%= bulan %>');
                if (el) el.classList.add('hidden');
            <% }); %>
        }

        function tampilkanBulan(bulan) {
            // Sembunyikan pesan default
            document.getElementById('pesan-pilih').classList.add('hidden');
            
            // Sembunyikan semua tabel
            sembunyikanSemuaTabel();
            
            // Tampilkan tabel bulan yang dipilih
            document.getElementById('tabel-' + bulan).classList.remove('hidden');
        }

        // Tutup modal jika klik di luar
        var modalRiwayat = document.getElementById('modalRiwayat');
        if (modalRiwayat) {
            modalRiwayat.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupRiwayat();
                }
            });
        }

        // Fungsi untuk Modal Pemasukan Lain (Hanya Admin)
        function bukaFormPemasukanLain() {
            document.getElementById('modalPemasukanLain').classList.remove('hidden');
        }

        function tutupFormPemasukanLain() {
            document.getElementById('modalPemasukanLain').classList.add('hidden');
        }

        // Tutup modal form pemasukan lain jika klik di luar
        var modalPemasukanLain = document.getElementById('modalPemasukanLain');
        if (modalPemasukanLain) {
            modalPemasukanLain.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupFormPemasukanLain();
                }
            });
        }

        // Fungsi untuk Modal List Pemasukan Lain (Hanya Admin)
        function bukaListPemasukanLain() {
            document.getElementById('modalListPemasukanLain').classList.remove('hidden');
        }

        function tutupListPemasukanLain() {
            document.getElementById('modalListPemasukanLain').classList.add('hidden');
        }

        // Tutup modal list pemasukan lain jika klik di luar
        var modalListPemasukanLain = document.getElementById('modalListPemasukanLain');
        if (modalListPemasukanLain) {
            modalListPemasukanLain.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupListPemasukanLain();
                }
            });
        }

        // Fungsi untuk Modal Pengeluaran (Hanya Admin)
        function bukaFormPengeluaran() {
            document.getElementById('modalPengeluaran').classList.remove('hidden');
        }

        function tutupFormPengeluaran() {
            document.getElementById('modalPengeluaran').classList.add('hidden');
        }

        // Tutup modal form pengeluaran jika klik di luar
        var modalPengeluaran = document.getElementById('modalPengeluaran');
        if (modalPengeluaran) {
            modalPengeluaran.addEventListener('click', function(e) {
                if (e.target === this) {
                    tutupFormPengeluaran();
                }
            });
        }
        <% } %>
    </script>
</body>
</html>