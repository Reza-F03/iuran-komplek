                            var isCurrentMonth = bulan === bulanBerjalan;
                        %>
                            <button 
                                onclick="tampilkanBulan('<%= bulan %>')" 
                                class="px-4 py-2 rounded-lg text-sm font-medium transition <%= isCurrentMonth ? 'bg-indigo-100 text-indigo-700 border-2 border-indigo-500' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                                <%= bulan %> <%= isCurrentMonth ? '(Berjalan)' : '' %>
                            </button>
                        <% }); %>
                    </div>
                </div>

                <!-- Tabel Data per Bulan -->
                <% semuaBulan.forEach(function(bulan) { %>
                    <div id="tabel-<%= bulan %>" class="hidden">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-lg font-bold text-gray-800">Data Iuran Bulan <%= bulan %> 2026</h3>
                            <a href="/download-excel-bulan/<%= bulan %>" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-medium px-3 py-2 rounded-lg transition">
                                📥 Download <%= bulan %>
                            </a>
                        </div>

                        <!-- Search Bar untuk Modal -->
                        <div class="mb-4">
                            <input type="text" id="searchModal<%= bulan %>" onkeyup="filterModalTable('<%= bulan %>')" 
                                placeholder="🔍 Cari nomor rumah atau nama warga..." 
                                class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        </div>
                        
                        <div class="overflow-x-auto border border-gray-200 rounded-xl">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-200">
                                        <th class="p-3 text-sm font-semibold text-gray-700">No. Rumah</th>
                                        <th class="p-3 text-sm font-semibold text-gray-700">Nama Warga</th>
                                        <th class="p-3 text-sm font-semibold text-gray-700 text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% warga.forEach(function(item) { 
                                        var status = item['status_' + bulan] || '-';
                                    %>
                                        <tr class="hover:bg-gray-50">
                                            <td class="p-3 text-sm font-semibold text-gray-900"><%= item.no_rumah %></td>
                                            <td class="p-3 text-sm text-gray-700"><%= item.nama %></td>
                                            <td class="p-3 text-center">
                                                <!-- Form untuk update status (ADMIN bisa edit bulan lalu) -->
                                                <form action="/update-iuran" method="POST" class="inline-block">
                                                    <input type="hidden" name="id" value="<%= item.id %>">
                                                    <input type="hidden" name="bulan" value="<%= bulan %>">
                                                    <select name="status" onchange="this.form.submit()" 
                                                        class="text-xs rounded-lg px-2.5 py-1.5 font-semibold border-0 cursor-pointer focus:ring-2 focus:ring-indigo-500 <%= status === 'Lunas' ? 'bg-green-100 text-green-800' : status === 'Belum Bayar' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-500' %>">
                                                        <option value="Lunas" <%= status === 'Lunas' ? 'selected' : '' %>>✓ Lunas</option>
                                                        <option value="Belum Bayar" <%= status === 'Belum Bayar' || status === '-' ? 'selected' : '' %>>✗ Belum Bayar</option>
                                                    </select>
                                                </form>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Statistik Ringkas -->
                        <div class="mt-4 grid grid-cols-2 gap-4">
                            <% 
                                var totalWarga = warga.length;
                                var lunas = warga.filter(function(w) { return w['status_' + bulan] === 'Lunas'; }).length;
                                var belumBayar = warga.filter(function(w) { return w['status_' + bulan] === 'Belum Bayar'; }).length;
                                var persentaseLunas = totalWarga > 0 ? Math.round((lunas / totalWarga) * 100) : 0;
                            %>
                            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                                <p class="text-xs text-green-600 font-medium">Total Lunas</p>
                                <p class="text-2xl font-bold text-green-700"><%= lunas %> <span class="text-sm text-green-600">/ <%= totalWarga %></span></p>
                            </div>
                            <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                                <p class="text-xs text-red-600 font-medium">Belum Bayar</p>
                                <p class="text-2xl font-bold text-red-700"><%= belumBayar %> <span class="text-sm text-red-600">/ <%= totalWarga %></span></p>
                            </div>
                        </div>

                        <!-- Progress Bar -->
                        <div class="mt-4">
                            <div class="flex justify-between text-xs text-gray-600 mb-1">
                                <span>Tingkat Pembayaran</span>
                                <span class="font-semibold"><%= persentaseLunas %>%</span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden">
                                <div class="bg-gradient-to-r from-green-500 to-emerald-600 h-3 rounded-full transition-all duration-500" style="width: <%= persentaseLunas %>%"></div>
                            </div>
                        </div>

                        <!-- Info Box untuk Admin -->
                        <div class="mt-4 bg-blue-50 border border-blue-200 rounded-xl p-4">
                            <p class="text-sm text-blue-900">
                                <strong>💡 Tip Admin:</strong> Anda bisa mengubah status pembayaran bulan <%= bulan %> dengan klik dropdown di kolom Status. 
                                Perubahan akan otomatis tersimpan dan mempengaruhi perhitungan keuangan.
                            </p>
                        </div>
                    </div>
                <% }); %>

                <!-- Pesan Default -->
                <div id="pesan-pilih" class="text-center py-12">
                    <div class="text-6xl mb-4">📊</div>
                    <p class="text-gray-500 text-sm">Pilih bulan di atas untuk melihat data riwayat</p>
                </div>
            </div>
        </div>
    </div>
