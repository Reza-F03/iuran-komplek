<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#4F46E5">
    <title>Aplikasi Monitoring Pembayaran Iuran Komplek Masihiro Residence</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Custom CSS untuk Mobile Optimization */
        @media (max-width: 640px) {
            /* Prevent zoom on input focus */
            input, select, textarea {
                font-size: 16px !important;
            }
            
            /* Smooth scrolling */
            html {
                scroll-behavior: smooth;
            }
            
            /* Better touch targets */
            button, a, input[type="submit"] {
                min-height: 44px;
                min-width: 44px;
            }
            
            /* Hide horizontal scrollbar but keep functionality */
            .overflow-x-auto::-webkit-scrollbar {
                height: 4px;
            }
            
            .overflow-x-auto::-webkit-scrollbar-thumb {
                background: #cbd5e0;
                border-radius: 4px;
            }
        }
        
        /* Loading animation */
        .fade-in {
            animation: fadeIn 0.3s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        /* Better modal backdrop for mobile */
        .modal-backdrop {
            backdrop-filter: blur(4px);
        }
        
        /* Pastikan footer modal selalu terlihat di mobile */
        @media (max-width: 640px) {
            .modal-footer-sticky {
                position: sticky;
                bottom: 0;
                z-index: 10;
            }
            
            /* Tombol download lebih besar di mobile untuk mudah diklik */
            .btn-download-mobile {
                min-height: 52px;
                font-size: 16px;
            }
        }
    </style>
</head>
<body class="bg-gray-50 min-h-screen p-4 sm:p-6">
    <div class="max-w-5xl mx-auto">
        
        <!-- Header & Login Area -->
        <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
            <div>
                <h1 class="text-2xl font-bold text-gray-800">Aplikasi Monitoring Pembayaran Iuran</h1>
                <h2 class="text-xl font-semibold text-indigo-600 mt-1">Komplek Masihiro Residence</h2>
                <p class="text-sm text-gray-500 mt-2">Status Anda: 
                    <span class="font-semibold <%= isAdmin ? 'text-indigo-600' : 'text-gray-600' %>">
                        <%= isAdmin ? '🤠 Administrator (Akses Penuh)' : '👤 Warga Biasa (Mode Lihat)' %>
                    </span>
                </p>
                <p class="text-xs text-gray-400 mt-1">
                    📅 Menampilkan iuran bulan <strong><%= bulanBerjalan %> 2026</strong> | Riwayat bulan lalu tersimpan otomatis
                </p>
            </div>
            
            <div class="flex flex-wrap items-center gap-3 w-full md:w-auto">
                <a href="/download-excel" class="bg-emerald-600 hover:bg-emerald-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📊 Rekap Iuran Bulanan
                </a>
                
                <!-- Tombol Riwayat Keuangan untuk SEMUA USER (Warga & Admin) -->
                <button onclick="bukaRiwayatKeuangan()" class="bg-purple-600 hover:bg-purple-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    💰 Riwayat Keuangan
                </button>
                
                <!-- Tombol Riwayat Pengeluaran untuk SEMUA USER (Warga & Admin) -->
                <button onclick="bukaListPengeluaran()" class="bg-orange-600 hover:bg-orange-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📋 Riwayat Pengeluaran
                </button>
                
                <!-- Tombol Riwayat Data Iuran untuk SEMUA USER (Warga & Admin) -->
                <button onclick="<%= isAdmin ? 'bukaRiwayat()' : 'bukaRiwayatWarga()' %>" class="bg-amber-600 hover:bg-amber-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📜 Riwayat Data Iuran
                </button>
                
                <% if (!isAdmin) { %>
                    <!-- Form Login Sederhana untuk Admin -->
                    <form action="/login" method="POST" class="flex items-center gap-2 border border-gray-200 p-1.5 rounded-xl bg-gray-50 w-full sm:w-auto">
                        <input type="password" name="password" placeholder="Password Admin..." required
                            class="bg-transparent text-sm px-2 py-1 outline-none w-full sm:w-36 text-gray-700 focus:ring-0">
                        <button type="submit" class="bg-gray-800 hover:bg-gray-900 text-white text-xs font-medium px-3 py-1.5 rounded-lg transition shrink-0">
                            Login Admin
                        </button>
                    </form>
                <% } else { %>
                    <a href="/logout" class="bg-rose-100 hover:bg-rose-200 text-rose-700 font-medium px-4 py-2 rounded-xl text-sm transition">
                        Logout
                    </a>
                <% } %>
            </div>
        </div>

        <!-- Panel Tambah Warga (HANYA MUNCUL JIKA ADMIN) -->
        <% if (isAdmin) { %>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-6">
                <h2 class="text-lg font-semibold text-gray-800 mb-4">🏠 Tambah Rumah/Warga Baru</h2>
                <form action="/tambah-warga" method="POST" class="grid grid-cols-1 sm:grid-cols-4 gap-4">
                    <input type="text" name="no_rumah" placeholder="Nomor Rumah (Contoh: B-12)" required
                        class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <input type="text" name="nama" placeholder="Nama Lengkap Pemilik" required
                        class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                    <select name="nominal_iuran" required
                        class="border border-gray-200 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                        <option value="30000">Rp 30.000</option>
                        <option value="50000">Rp 50.000</option>
                        <option value="100000">Rp 100.000</option>
                    </select>
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-xl text-sm transition">
                        + Daftarkan Rumah
                    </button>
                </form>
            </div>
        <% } %>

        <!-- Dashboard Keuangan (HANYA ADMIN) -->
        <% if (isAdmin) { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
                <!-- Total Pemasukan Iuran -->
                <div class="bg-gradient-to-br from-emerald-500 to-green-600 p-6 rounded-2xl shadow-lg text-white">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium opacity-90">💵 Pemasukan Iuran</span>
                    </div>
                    <p class="text-2xl font-bold">Rp <%= keuangan.totalPemasukanIuran.toLocaleString('id-ID') %></p>
                    <p class="text-xs opacity-75 mt-1"><%= bulanBerjalan %> 2026</p>
                </div>
                
                <!-- Total Pemasukan Lain-lain -->
                <div class="bg-gradient-to-br from-teal-500 to-cyan-600 p-6 rounded-2xl shadow-lg text-white">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium opacity-90">💰 Pemasukan Lain</span>
                    </div>
                    <p class="text-2xl font-bold">Rp <%= keuangan.totalPemasukanLain.toLocaleString('id-ID') %></p>
                    <p class="text-xs opacity-75 mt-1"><%= bulanBerjalan %> 2026</p>
                </div>
                
                <!-- Total Pengeluaran -->
                <div class="bg-gradient-to-br from-red-500 to-rose-600 p-6 rounded-2xl shadow-lg text-white">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium opacity-90">💸 Pengeluaran</span>
                    </div>
                    <p class="text-2xl font-bold">Rp <%= keuangan.totalPengeluaran.toLocaleString('id-ID') %></p>
                    <p class="text-xs opacity-75 mt-1"><%= bulanBerjalan %> 2026</p>
                </div>
                
                <!-- Sisa Kas Bulan Ini -->
                <div class="bg-gradient-to-br from-blue-500 to-indigo-600 p-6 rounded-2xl shadow-lg text-white">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium opacity-90">🏦 Kas/bulan</span>
                    </div>
                    <p class="text-2xl font-bold">Rp <%= keuangan.sisaKas.toLocaleString('id-ID') %></p>
                    <p class="text-xs opacity-75 mt-1">Bulan <%= bulanBerjalan %></p>
                </div>

                <!-- Total Kumulatif Kas -->
                <div class="bg-gradient-to-br from-purple-600 to-pink-600 p-6 rounded-2xl shadow-lg text-white">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-xs font-medium opacity-90">🎯 Total Kas</span>
                    </div>
                    <p class="text-2xl font-bold">Rp <%= totalKumulatif.toLocaleString('id-ID') %></p>
                    <p class="text-xs opacity-75 mt-1">Jan - <%= bulanBerjalan %></p>
                </div>
            </div>

            <!-- Tombol Kelola Keuangan -->
            <div class="bg-white p-4 rounded-2xl shadow-sm border border-gray-100 mb-6 flex flex-wrap gap-3">
                <button onclick="bukaFormPemasukanLain()" class="bg-teal-600 hover:bg-teal-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    ➕ Tambah Pemasukan Lain
                </button>
                <button onclick="bukaFormPengeluaran()" class="bg-rose-600 hover:bg-rose-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    ➕ Tambah Pengeluaran
                </button>
                <button onclick="bukaListPemasukanLain()" class="bg-cyan-600 hover:bg-cyan-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📋 Riwayat Pemasukan Lain
                </button>
                <button onclick="bukaListPengeluaran()" class="bg-orange-600 hover:bg-orange-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📋 Riwayat Pengeluaran
                </button>
                <button onclick="bukaRiwayatKeuangan()" class="bg-purple-600 hover:bg-purple-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    💰 Riwayat Keuangan
                </button>
                <button onclick="<%= isAdmin ? 'bukaRiwayat()' : 'bukaRiwayatWarga()' %>" class="bg-amber-600 hover:bg-amber-700 text-white font-medium px-4 py-2 rounded-xl text-sm shadow-sm transition">
                    📜 Riwayat Data Iuran
                </button>
            </div>
        <% } %>

        <!-- Tabel Monitoring Utama -->
       <!-- Tabel Monitoring Utama -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
            <!-- Search Bar -->
            <div class="p-4 border-b border-gray-100 bg-gray-50">
                <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center">
                    <div class="flex-1">
                        <input type="text" id="searchInput" onkeyup="filterTable()" placeholder="🔍 Cari nomor rumah atau nama warga..." 
                            class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                    </div>
                    <% if (isAdmin) { %>
                        <select id="filterStatus" onchange="filterTable()" class="border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <option value="">📊 Semua Status</option>
                            <option value="Lunas">✓ Lunas</option>
                            <option value="Belum Bayar">✗ Belum Bayar</option>
                        </select>
                        <select id="filterNominal" onchange="filterTable()" class="border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <option value="">💰 Semua Nominal</option>
                            <option value="30000">Rp 30.000</option>
                            <option value="50000">Rp 50.000</option>
                            <option value="100000">Rp 100.000</option>
                        </select>
                    <% } %>
                </div>
                <p id="searchResult" class="text-xs text-gray-500 mt-2 hidden">Ditemukan <span id="resultCount">0</span> data</p>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50 text-gray-600 text-sm font-semibold border-b border-gray-100">
                            <th class="p-4">No. Rumah</th>
                            <th class="p-4">Nama Warga</th>
                            <% if (isAdmin) { %><th class="p-4 text-center">Nominal Iuran</th><% } %>
                            <!-- Kolom untuk BULAN BERJALAN saja -->
                            <th class="p-4 text-center">Iuran <%= bulanBerjalan %> 2026</th>
                            <% if (isAdmin) { %><th class="p-4 text-center">Tindakan</th><% } %>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-100 text-gray-700 text-sm" id="tableBody">
                        <% warga.forEach(function(item) { %>
                            <!-- BARIS MODE TAMPILAN BIASA -->
                            <tr id="row-view-<%= item.id %>" class="hover:bg-gray-50/50 transition table-row" 
                                data-rumah="<%= item.no_rumah.toLowerCase() %>" 
                                data-nama="<%= item.nama.toLowerCase() %>" 
                                data-status="<%= item['status_' + bulanBerjalan] || 'Belum Bayar' %>"
                                data-nominal="<%= item.nominal_iuran || 50000 %>">
                                <td class="p-4 font-bold text-gray-900"><%= item.no_rumah %></td>
                                <td class="p-4"><%= item.nama %></td>
                                
                                <!-- Kolom Nominal Iuran (hanya untuk admin) -->
                                <% if (isAdmin) { %>
                                    <td class="p-4 text-center">
                                        <span class="text-xs font-semibold px-2.5 py-1 rounded-lg <%= item.nominal_iuran === 100000 ? 'bg-purple-100 text-purple-800' : item.nominal_iuran === 50000 ? 'bg-blue-100 text-blue-800' : 'bg-teal-100 text-teal-800' %>">
                                            Rp <%= (item.nominal_iuran || 50000).toLocaleString('id-ID') %>
                                        </span>
                                    </td>
                                <% } %>
                                
                                <!-- Kolom Status Iuran untuk BULAN BERJALAN saja -->
                                <% 
                                    var statusBulan = item['status_' + bulanBerjalan] || 'Belum Bayar';
                                %>
                                <td class="p-4 text-center">
                                    <% if (isAdmin) { %>
                                        <form action="/update-iuran" method="POST" class="inline-block">
                                            <input type="hidden" name="id" value="<%= item.id %>">
                                            <input type="hidden" name="bulan" value="<%= bulanBerjalan %>">
                                            <select name="status" onchange="this.form.submit()" 
                                                class="text-xs rounded-lg px-2.5 py-1 font-semibold border-0 cursor-pointer focus:ring-2 focus:ring-indigo-500
                                                <%= statusBulan === 'Lunas' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                                <option value="Lunas" <%= statusBulan === 'Lunas' ? 'selected' : '' %>>Lunas</option>
                                                <option value="Belum Bayar" <%= statusBulan === 'Belum Bayar' ? 'selected' : '' %>>Belum Bayar</option>
                                            </select>
                                        </form>
                                    <% } else { %>
                                        <span class="text-xs font-semibold px-2.5 py-1 rounded-lg <%= statusBulan === 'Lunas' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                            <%= statusBulan %>
                                        </span>
                                    <% } %>
                                </td>

                                <!-- Tombol Tindakan Admin -->
                                <% if (isAdmin) { %>
                                    <td class="p-4 text-center flex justify-center gap-3">
                                        <button type="button" onclick="bukaModeEdit('<%= item.id %>')" class="text-xs font-medium text-indigo-600 hover:text-indigo-800 hover:underline">
                                            Edit
                                        </button>
                                        <form action="/hapus-warga" method="POST" onsubmit="return confirm('Hapus data rumah <%= item.no_rumah %>?')" class="inline-block">
                                            <input type="hidden" name="id" value="<%= item.id %>">
                                            <button type="submit" class="text-xs font-medium text-rose-600 hover:text-rose-800 hover:underline">
                                                Hapus
                                            </button>
                                        </form>
                                    </td>
                                <% } %>
                            </tr>

                            <!-- BARIS MODE EDIT INLINE -->
                            <% if (isAdmin) { %>
                                <tr id="row-edit-<%= item.id %>" class="bg-indigo-50/50 hidden">
                                    <form action="/edit-warga" method="POST">
                                        <input type="hidden" name="id" value="<%= item.id %>">
                                        <td class="p-3">
                                            <input type="text" name="no_rumah" value="<%= item.no_rumah %>" required
                                                class="w-full text-xs border border-gray-300 rounded px-2 py-1 focus:ring-1 focus:ring-indigo-500">
                                        </td>
                                        <td class="p-3">
                                            <input type="text" name="nama" value="<%= item.nama %>" required
                                                class="w-full text-xs border border-gray-300 rounded px-2 py-1 focus:ring-1 focus:ring-indigo-500">
                                        </td>
                                        <td class="p-3">
                                            <select name="nominal_iuran" required
                                                class="w-full text-xs border border-gray-300 rounded px-2 py-1 focus:ring-1 focus:ring-indigo-500">
                                                <option value="30000" <%= item.nominal_iuran === 30000 ? 'selected' : '' %>>Rp 30.000</option>
                                                <option value="50000" <%= item.nominal_iuran === 50000 ? 'selected' : '' %>>Rp 50.000</option>
                                                <option value="100000" <%= item.nominal_iuran === 100000 ? 'selected' : '' %>>Rp 100.000</option>
                                            </select>
                                        </td>
                                        
                                        <!-- Kolom status dikunci otomatis saat mode edit -->
                                        <td class="p-3 text-center text-gray-400 text-xs italic">Kunci saat edit</td>
                                        
                                        <td class="p-3 text-center flex justify-center gap-2">
                                            <button type="submit" class="bg-indigo-600 text-white text-xs px-2.5 py-1 rounded hover:bg-indigo-700 transition font-medium">
                                                Simpan
                                            </button>
                                            <button type="button" onclick="tutupModeEdit('<%= item.id %>')" class="bg-gray-200 text-gray-700 text-xs px-2.5 py-1 rounded hover:bg-gray-300 transition font-medium">
                                                Batal
                                            </button>
                                        </td>
                                    </form>
                                </tr>
                            <% } %>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <!-- Footer Copyright -->
    <footer class="max-w-5xl mx-auto mt-8 mb-4">
        <div class="bg-white p-4 rounded-xl shadow-sm border border-gray-100">
            <p class="text-center text-sm text-gray-600">
                © 2026 <strong class="text-indigo-600">Reza</strong> - Komplek Masihiro Residence. All rights reserved.
            </p>
        </div>
    </footer>

    <!-- Modal Riwayat Bulan untuk WARGA (Read-Only) -->
    <% if (!isAdmin) { %>
    <div id="modalRiwayatWarga" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-hidden">
            <!-- Header Modal -->
            <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-6 text-white">
                <div class="flex justify-between items-center">
                    <div>
                        <h2 class="text-2xl font-bold">📜 Riwayat Data Iuran Saya</h2>
                        <p class="text-sm text-indigo-100 mt-1">Data pembayaran iuran Anda dari Januari sampai Desember</p>
                    </div>
                    <button onclick="tutupRiwayatWarga()" class="text-white hover:text-indigo-200 text-2xl font-bold transition">
                        ✕
                    </button>
                </div>
            </div>

            <!-- Isi Modal -->
            <div class="p-6 overflow-y-auto max-h-[calc(90vh-120px)]">
                <!-- Filter Bulan -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-3">Pilih Bulan untuk Ditampilkan:</label>
                    <div class="flex flex-wrap gap-2">
                        <% semuaBulan.forEach(function(bulan) { 
                            var isCurrentMonth = bulan === bulanBerjalan;
                        %>
                            <button 
                                onclick="tampilkanBulanWarga('<%= bulan %>')" 
                                class="px-4 py-2 rounded-lg text-sm font-medium transition <%= isCurrentMonth ? 'bg-indigo-100 text-indigo-700 border-2 border-indigo-500' : 'bg-gray-100 text-gray-700 hover:bg-gray-200' %>">
                                <%= bulan %> <%= isCurrentMonth ? '(Berjalan)' : '' %>
                            </button>
                        <% }); %>
                    </div>
                </div>

                <!-- Tabel Data per Bulan -->
                <% semuaBulan.forEach(function(bulan) { %>
                    <div id="tabel-warga-<%= bulan %>" class="hidden">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="text-lg font-bold text-gray-800">Data Iuran Bulan <%= bulan %> 2026</h3>
                        </div>

                        <!-- Search Bar untuk Modal Warga -->
                        <div class="mb-4">
                            <input type="text" id="searchModalWarga<%= bulan %>" onkeyup="filterModalTableWarga('<%= bulan %>')" 
                                placeholder="🔍 Cari nomor rumah atau nama warga..." 
                                class="w-full border border-gray-300 rounded-xl px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
                            <p id="searchResultWarga<%= bulan %>" class="text-xs text-gray-500 mt-2 hidden">Ditemukan <span id="resultCountWarga<%= bulan %>">0</span> data</p>
                        </div>
                        
                        <div class="overflow-x-auto border border-gray-200 rounded-xl">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="bg-gray-50 border-b border-gray-200">
                                        <th class="p-3 text-sm font-semibold text-gray-700">No. Rumah</th>
                                        <th class="p-3 text-sm font-semibold text-gray-700">Nama Warga</th>
                                        <th class="p-3 text-sm font-semibold text-gray-700 text-center">Status</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100" id="tableBodyWarga<%= bulan %>">
                                    <% warga.forEach(function(item) { 
                                        var status = item['status_' + bulan] || '-';
                                    %>
                                        <tr class="hover:bg-gray-50 row-warga-<%= bulan %>" 
                                            data-rumah="<%= item.no_rumah.toLowerCase() %>" 
                                            data-nama="<%= item.nama.toLowerCase() %>">
                                            <td class="p-3 text-sm font-semibold text-gray-900"><%= item.no_rumah %></td>
                                            <td class="p-3 text-sm text-gray-700"><%= item.nama %></td>
                                            <td class="p-3 text-center">
                                                <!-- Read-only badge untuk warga -->
                                                <span class="text-xs rounded-lg px-2.5 py-1.5 font-semibold <%= status === 'Lunas' ? 'bg-green-100 text-green-800' : status === 'Belum Bayar' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-500' %>">
                                                    <%= status === 'Lunas' ? '✓ Lunas' : status === 'Belum Bayar' ? '✗ Belum Bayar' : '-' %>
                                                </span>
                                            </td>
                                        </tr>
                                    <% }); %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Statistik Ringkas -->
                        <div class="mt-4 grid grid-cols-2 gap-4">
                            <% 
                                var totalWarga = warga.length;
                                var lunas = warga.filter(function(w) { return w['status_' + bulan] === 'Lunas'; }).length;
                                var belumBayar = warga.filter(function(w) { return w['status_' + bulan] === 'Belum Bayar'; }).length;
                                var persentaseLunas = totalWarga > 0 ? Math.round((lunas / totalWarga) * 100) : 0;
