                            <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                                <p class="text-xs text-green-600 font-medium">Total Lunas</p>
                                <p class="text-2xl font-bold text-green-700"><%= lunas %> <span class="text-sm text-green-600">/ <%= totalWarga %></span></p>
                            </div>
                            <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                                <p class="text-xs text-red-600 font-medium">Belum Bayar</p>
